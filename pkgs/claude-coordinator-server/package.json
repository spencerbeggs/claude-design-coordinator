{
	"name": "@spencerbeggs/claude-coordinator-server",
	"version": "0.1.0",
	"description": "tRPC WebSocket server for Claude Coordinator",
	"keywords": ["claude", "coordinator", "trpc", "websocket", "server"],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/claude-design-coordinator.git",
		"directory": "pkgs/claude-coordinator-server"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"bin": {
		"claude-coordinator-server": "./src/bin/cli.ts"
	},
	"scripts": {
		"build:dev": "rslib build --env-mode dev",
		"build:prod": "rslib build --env-mode npm",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@spencerbeggs/claude-coordinator-core": "workspace:*",
		"@trpc/server": "^11.17.0",
		"ws": "^8.21.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@rslib/core": "^0.22.0",
		"@savvy-web/rslib-builder": "^0.21.3",
		"@types/node": "catalog:silk",
		"@types/ws": "^8.18.1",
		"@typescript/native-preview": "catalog:silk",
		"typescript": "catalog:silk",
		"vitest": "^4.1.7"
	},
	"engines": {
		"node": ">=24.1.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
