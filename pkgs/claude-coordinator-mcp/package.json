{
	"name": "@spencerbeggs/claude-coordinator-mcp",
	"version": "0.1.1",
	"description": "MCP stdio bridge for Claude Coordinator",
	"keywords": ["claude", "coordinator", "mcp", "model-context-protocol"],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/claude-design-coordinator.git",
		"directory": "pkgs/claude-coordinator-mcp"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"bin": {
		"claude-coordinator-mcp": "./src/bin/cli.ts"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "node savvy.build.ts --target dev",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@spencerbeggs/claude-coordinator-core": "workspace:*",
		"@spencerbeggs/claude-coordinator-server": "workspace:*",
		"@trpc/client": "^11.18.0",
		"@trpc/server": "^11.18.0",
		"ws": "^8.21.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^1.1.14",
		"@types/node": "catalog:silk",
		"@types/ws": "^8.18.1",
		"typescript": "catalog:silk",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": true
		}
	}
}
